---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div
  id="reading-bar"
  class="fixed top-0 left-0 right-0 z-[55] -translate-y-full transition-transform duration-300 ease-in-out"
  aria-hidden="true"
>
  <div class="glass-b px-4 py-2 shadow-lg">
    <div class="mx-auto flex w-full max-w-5xl items-center gap-3">
      <!-- Title -->
      <span class="font-notoLooped line-clamp-1 flex-1 text-sm font-medium text-txt-p dark:text-darkmode-txt-p">
        {title}
      </span>

      <!-- Gear icon + reader settings panel -->
      <div class="relative inline-flex" data-reader-settings>
        <button
          type="button"
          class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border/70 bg-bg-p/80 text-txt-p shadow-sm transition-colors hover:bg-bg-s/80 dark:border-darkmode-border/80 dark:bg-darkmode-bg-t/70 dark:text-darkmode-txt-p dark:hover:bg-darkmode-bg-s/70"
          data-reader-settings-trigger
          aria-label="Open reading settings"
          aria-expanded="false"
          aria-controls="reading-bar-settings-panel"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3.2"></circle>
            <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .98 1.99 1.99 0 0 1-3.98 0 1.7 1.7 0 0 0-1-.98 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.98-1 1.99 1.99 0 0 1 0-3.98 1.7 1.7 0 0 0 .98-1 1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.98 1.99 1.99 0 0 1 3.98 0 1.7 1.7 0 0 0 1 .98 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c0 .41.16.8.44 1.1.29.28.68.44 1.08.44a1.99 1.99 0 0 1 0 3.98c-.4 0-.79.16-1.08.44-.28.3-.44.69-.44 1.1Z"></path>
          </svg>
        </button>

        <div
          id="reading-bar-settings-panel"
          class="absolute right-0 top-full z-[70] mt-2 hidden w-[min(20rem,calc(100vw-1rem))] overflow-hidden rounded-2xl border border-border bg-bg-p/95 p-4 shadow-xl backdrop-blur md:w-80 dark:border-darkmode-border dark:bg-[#10181d]/95"
          data-reader-settings-panel
        >
          <div class="space-y-4 text-sm text-txt-p dark:text-darkmode-txt-p">
            <!-- Font size -->
            <section class="space-y-2">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-semibold">ขนาดตัวอักษร</h2>
                <span class="text-xs text-txt-light dark:text-darkmode-txt-light" data-reader-font-size-label>มาตรฐาน</span>
              </div>
              <div class="grid grid-cols-2 overflow-hidden rounded-xl border border-border dark:border-darkmode-border">
                <button
                  type="button"
                  class="reader-option-btn border-r border-border px-4 py-2.5 text- font-notoLooped dark:border-darkmode-border"
                  data-reader-font-size-step="decrease"
                >
                  มาตรฐาน
                </button>
                <button
                  type="button"
                  class="reader-option-btn px-4 py-2.5 text-base font-notoLooped"
                  data-reader-font-size-step="increase"
                >
                  ใหญ่
                </button>
              </div>
            </section>

            <!-- Theme color -->
            <section class="space-y-2">
              <h2 class="text-sm font-semibold">ธีมสี</h2>
              <div class="grid grid-cols-3 overflow-hidden rounded-xl border border-border dark:border-darkmode-border">
                <button type="button" class="reader-option-btn px-3 py-2.5" data-reader-theme-option="light" aria-pressed="false">
                  สว่าง
                </button>
                <button type="button" class="reader-option-btn border-x border-border px-3 py-2.5 dark:border-darkmode-border" data-reader-theme-option="eye-care" aria-pressed="false">
                  ถนอมตา
                </button>
                <button type="button" class="reader-option-btn px-3 py-2.5" data-reader-theme-option="dark" aria-pressed="false">
                  มืด
                </button>
              </div>
            </section>

            <!-- Line height -->
            <section class="space-y-2">
              <h2 class="text-sm font-semibold">ระยะห่างบรรทัด</h2>
              <div class="grid grid-cols-3 overflow-hidden rounded-xl border border-border dark:border-darkmode-border">
                <button type="button" class="reader-option-btn px-3 py-2.5" data-reader-line-height-option="compact" aria-pressed="false">
                  แน่น
                </button>
                <button type="button" class="reader-option-btn border-x border-border px-3 py-2.5 dark:border-darkmode-border" data-reader-line-height-option="relaxed" aria-pressed="false">
                  พอดี
                </button>
                <button type="button" class="reader-option-btn px-3 py-2.5" data-reader-line-height-option="loose" aria-pressed="false">
                  โปร่ง
                </button>
              </div>
            </section>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .reader-option-btn {
    transition: background-color 160ms ease, color 160ms ease;
  }

  .reader-option-btn:hover {
    background-color: rgba(174, 134, 201, 0.16);
  }

  .reader-option-btn[data-reader-active="true"] {
    background-color: rgb(55 65 81);
    color: rgb(255 255 255);
  }

  :global(html.dark) .reader-option-btn[data-reader-active="true"] {
    background-color: rgb(17 24 39);
    color: rgb(255 255 255);
  }

  :global(html[data-reader-theme="eye-care"]) .reader-option-btn[data-reader-active="true"] {
    background-color: rgb(66 93 80);
    color: rgb(244 239 222);
  }
</style>

<script is:inline>
  function initReadingBar() {
    const bar = document.getElementById("reading-bar");
    const content = document.querySelector(".content");
    if (!bar || !content) return;

    if (bar._readingBarCleanup) {
      bar._readingBarCleanup();
    }

    const updateVisibility = () => {
      const contentRect = content.getBoundingClientRect();
      const show = contentRect.top <= 0;
      bar.classList.toggle("-translate-y-full", !show);
      bar.setAttribute("aria-hidden", String(!show));
    };

    updateVisibility();

    window.addEventListener("scroll", updateVisibility, { passive: true });
    window.addEventListener("resize", updateVisibility);

    bar._readingBarCleanup = () => {
      window.removeEventListener("scroll", updateVisibility);
      window.removeEventListener("resize", updateVisibility);
    };
  }

  // Re-use the same initReaderSettingsMenu from ThemeSwitcher — it selects all
  // [data-reader-settings] roots so it will initialize the reading bar panel too.
  // We call it here after astro:page-load to catch the reading bar's panel.
  function initReadingBarMenu() {
    const root = document.querySelector("#reading-bar [data-reader-settings]");
    if (!root || root.dataset.initialized === "true") return;

    root.dataset.initialized = "true";

    const trigger = root.querySelector("[data-reader-settings-trigger]");
    const panel = root.querySelector("[data-reader-settings-panel]");

    if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

    const setOpen = (open) => {
      panel.classList.toggle("hidden", !open);
      trigger.setAttribute("aria-expanded", String(open));
    };

    trigger.addEventListener("click", () => {
      setOpen(panel.classList.contains("hidden"));
    });

    document.addEventListener("click", (event) => {
      if (!root.contains(event.target)) setOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
  }

  function init() {
    initReadingBar();
    initReadingBarMenu();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
